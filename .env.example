# ─────────────────────────────────────────────────────────
# OzBiz Frontend — Environment Variables
# Copy to .env.local for local dev
# Set in Vercel Dashboard → Settings → Environment Variables for production
# ─────────────────────────────────────────────────────────

# Backend API URL (production only — Vite proxy handles local dev)
VITE_API_URL=https://ozbiz-backend.vercel.app/api/

# Google OAuth Client ID (optional — enables "Sign in with Google")
# Get from https://console.cloud.google.com → Credentials → OAuth 2.0 Client ID
# Add authorized origins: http://localhost:5173 and https://ozbiz.vercel.app
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
